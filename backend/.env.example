NODE_ENV=development
PORT=8000

# PostgreSQL — substitua usuário, senha, host e nome do banco
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>?schema=public

# Redis — substitua host e porta se necessário
REDIS_URL=redis://<REDIS_HOST>:6379

# JWT — gere segredos fortes em produção (ex: openssl rand -hex 64)
JWT_SECRET=<your-strong-jwt-secret>
JWT_REFRESH_SECRET=<your-strong-refresh-secret>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cabeçalho de versionamento da API
API_VERSION_HEADER=X-API-Version

# Origem permitida pelo CORS (URL do front-end)
CORS_ORIGIN=http://localhost:3001
